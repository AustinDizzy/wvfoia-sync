---
import StatusBadge from "./StatusBadge.astro";
import { href } from "$/lib/links";
import type { Entry } from "$/lib/types";
import { diffHuman, formatDate, formatRequestor } from "$/lib/utils";

interface Props {
  entries: Entry[];
  showAgency?: boolean;
  emptyMessage?: string;
}

const { entries, showAgency = true, emptyMessage } = Astro.props;
---

<div class="divide-y divide-border-soft md:hidden">
  {entries.map((entry) => {
    const requestorText = formatRequestor(entry);
    const entryHref = href(`entries/${entry.id}`);
    const completedDate = formatDate(entry.completion_date, true);
    const completedDelta = diffHuman(entry.request_date, entry.completion_date);

    return (
      <a
        class="grid grid-cols-[minmax(0,1fr)_auto] items-start gap-3 px-3 py-3 hover:bg-slate-50 focus-visible:outline-none focus-visible:shadow-[inset_0_0_0_2px_var(--focus)] dark:hover:bg-[#1f1f1f]"
        href={entryHref}
      >
        <div class="grid min-w-0 grid-cols-[auto_minmax(0,1fr)] gap-x-5 gap-y-2 text-xs leading-4 text-muted">
          <div class="min-w-0">
            <div class="font-mono text-[10px] uppercase tracking-wide text-faint">Requested</div>
            <div class="font-mono text-xs uppercase text-muted">{formatDate(entry.request_date, true)}</div>
          </div>
          <div class="min-w-0">
            <div class="line-clamp-3 text-sm leading-5 text-fg">{entry.subject || "--"}</div>
          </div>
          <div class="min-w-0">
            <div class="font-mono text-[10px] uppercase tracking-wide text-faint">Completed</div>
            <div class="text-xs leading-4 text-fg">{completedDate}</div>
            <div class="text-xs leading-4 text-muted">{completedDelta}</div>
          </div>
          {showAgency && (
            <div class="min-w-0">
              <div class="font-mono text-[10px] uppercase tracking-wide text-faint">Agency</div>
              <div class="truncate text-fg">{entry.agency}</div>
            </div>
          )}
          <div class:list={["min-w-0", showAgency && "col-start-2"]}>
            <div class="font-mono text-[10px] uppercase tracking-wide text-faint">Requestor</div>
            <div class="truncate text-fg">{requestorText}</div>
          </div>
        </div>
        <div class="shrink-0"><StatusBadge resolution={entry.resolution} /></div>
      </a>
    );
  })}
</div>

<table class="hidden w-full text-sm leading-5 md:table [&_td]:p-0">
  <thead class="border-b border-border bg-surface-muted font-mono text-[11px] uppercase">
    <tr>
      <th class="px-3 py-2 text-left lg:px-4">Request</th>
      <th class="px-3 py-2 text-left lg:px-4">Requestor</th>
      <th class="px-3 py-2 text-left lg:px-4">Subject</th>
      {showAgency && <th class="px-3 py-2 text-left lg:px-4">Agency</th>}
      <th class="px-3 py-2 text-left lg:px-4">Status</th>
      <th class="px-3 py-2 text-left lg:px-4">Completed</th>
    </tr>
  </thead>
  <tbody>
    {entries.map((entry) => {
      const requestorName = [entry.first_name, entry.middle_name, entry.last_name].filter(Boolean).join(" ");
      const requestorText = formatRequestor(entry);
      const cellLinkClass = "block px-3 py-2.5 lg:px-4";
      const requestorClass = requestorName
        ? `${cellLinkClass} whitespace-nowrap`
        : `${cellLinkClass} whitespace-normal`;
      const entryHref = href(`entries/${entry.id}`);

      return (
        <tr class="border-b border-border-soft hover:bg-slate-50 focus-within:bg-slate-50 dark:hover:bg-[#1f1f1f] dark:focus-within:bg-[#1f1f1f]">
          <td><a class={`${cellLinkClass} whitespace-nowrap`} href={entryHref}>{formatDate(entry.request_date, true)}</a></td>
          <td><a class={requestorClass} href={entryHref}>{requestorText}</a></td>
          <td><a class={cellLinkClass} href={entryHref}>{entry.subject || "--"}</a></td>
          {showAgency && <td><a class={cellLinkClass} href={entryHref}>{entry.agency}</a></td>}
          <td><a class={`${cellLinkClass} focus-visible:outline-none focus-visible:shadow-[inset_0_0_0_2px_var(--focus)]`} href={entryHref}><StatusBadge resolution={entry.resolution} /></a></td>
          <td><a class={cellLinkClass} href={entryHref}>{formatDate(entry.completion_date, true)}<div class="text-xs text-muted">{diffHuman(entry.request_date, entry.completion_date)}</div></a></td>
        </tr>
      );
    })}
  </tbody>
</table>

{emptyMessage && entries.length === 0 && <div class="px-3 py-2 text-muted sm:px-4">{emptyMessage}</div>}
